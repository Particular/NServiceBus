<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <RootNamespace>NServiceBus.ContentionStress</RootNamespace>
    <AssemblyName>InMemory.ContentionStress</AssemblyName>
    <!-- Throwaway investigation harness: keep analyzer friction low -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <EnableNETAnalyzers>false</EnableNETAnalyzers>
    <EnforceCodeStyleInBuild>false</EnforceCodeStyleInBuild>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <NoWarn>$(NoWarn);CA1822;CA1051;CA1707;CA1851;CA1845;IDE0060</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\NServiceBus.Core\NServiceBus.Core.csproj" />
    <ProjectReference Include="..\NServiceBus.InMemory\NServiceBus.InMemory.csproj" />
  </ItemGroup>

</Project>
